# Pick the variable that matches your provider preset in the app settings.
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
CEREBRAS_API_KEY=your-cerebras-key-here
SAMBANOVA_API_KEY=your-sambanova-key-here
DEEPINFRA_TOKEN=your-deepinfra-token-here
GROQ_API_KEY=gsk_your_groq_key_here
TOGETHER_API_KEY=your_together_key_here
FIREWORKS_API_KEY=your_fireworks_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
XAI_API_KEY=your_xai_key_here
# OLLAMA_API_KEY is optional for local Ollama and ignored by localhost installs.
OLLAMA_API_KEY=optional-for-local-ollama
